{
  "AI": {
    "Provider": "openai",
    "Model": "gpt-4o",
    "ApiKey": "",
    "Endpoint": "",
    "Compaction": {
      "Mode": "Pipeline",
      "ToolResult": { "TokensThreshold": 8192 },
      "Summarization": {
        "TokensThreshold": 20480,
        "MinimumPreservedGroups": 8,
        "Model": ""
      },
      "SlidingWindow": {
        "TurnsThreshold": 6,
        "PreservedTurns": 4
      },
      "Truncation": {
        "TokensThreshold": 65536,
        "PreservedMessages": 8
      }
    },
    "ResearchContextProvider": {
      "Enabled": true
    }
  },
  "Logging": {
    "MinLevel": "Information"
  },
  "Telemetry": {
    "Enabled": false
  },
  "Research": {
    "MaxIterations": 2,
    "VerificationEnabled": true,
    "Search": {
      "Provider": "Tavily"
    },
    "Tavily": {
      "SearchDepth": "basic"
    },
    "EvidenceGate": {
      "Mode": "Warn",
      "MinFindingsPerQuestion": 2,
      "MinDistinctDomainsPerQuestion": 2,
      "MinMeanConfidence": 0.5,
      "MaxSimulatedSourceRatio": 0.0
    }
  },
  "Output": {
    "ShowHistory": false,
    "ShowContextLog": false,
    "SessionDir": "sessions"
  }
}
