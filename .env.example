# Environment configuration for MCP Server and AgentAlpha
# Copy this file to .env and update the values

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# GitHub API Configuration
GITHUB_ACCESS_TOKEN=your_github_access_token_here

# Azure DevOps API Configuration
AZURE_DEVOPS_ACCESS_TOKEN=your_azure_devops_access_token_here

# MCP Server Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:3000

# MCP Transport Configuration
# Options: stdio, sse
MCP_TRANSPORT=stdio
MCP_SERVER_URL=http://localhost:3000

# Logging Configuration
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT=Warning
LOGGING__LOGLEVEL__MICROSOFT_HOSTING_LIFETIME=Information

# AgentAlpha Configuration
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300
# Model for conversation and general tasks (default: gpt-4.1)
AGENT_MODEL=gpt-4.1
# Model for planning tasks - use reasoning models for better planning (optional)
# Examples: o1-preview, o1-mini, o3, o3-mini
PLANNING_MODEL=o1-preview

# Tool-Approval Provider
APPROVAL_PROVIDER_TYPE=Console

# File-based provider
FILE_APPROVAL_DIRECTORY=./approvals
FILE_APPROVAL_POLL_INTERVAL=00:00:01
FILE_APPROVAL_TIMEOUT=00:05:00

# REST-based provider
REST_BASE_URL=http://localhost:5000/
REST_POLL_INTERVAL=00:00:02
REST_TIMEOUT=00:10:00
REST_AUTH_TOKEN=your_token_here