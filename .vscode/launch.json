{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ApprovalService",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/ApprovalService/bin/Debug/net8.0/ApprovalService.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/ApprovalService",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:approval-service",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5000"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "MCP Server (SSE Mode)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/MCPServer/bin/Debug/net8.0/MCPServer.dll",
            "args": ["--transport", "sse"],
            "cwd": "${workspaceFolder}/src/MCPServer",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:mcp-server",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:3000",
                "MCP_TRANSPORT": "sse"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "AgentAlpha (SSE)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Agent/AgentAlpha/bin/Debug/net8.0/AgentAlpha.dll",
            "args": ["I'm running in a linux terminal and I want to list all the files in my current directory"],
            "cwd": "${workspaceFolder}/src/Agent/AgentAlpha",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:agent-alpha",
            "env": {
                "MCP_TRANSPORT": "sse",
                "MCP_SERVER_URL": "http://localhost:3000"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "AgentAlpha (Enhanced - GPT-4)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Agent/AgentAlpha/bin/Debug/net8.0/AgentAlpha.dll",
            "args": ["--model", "gpt-4o", "--temperature", "0.7", "--verbose", "Analyze the repository structure and suggest improvements"],
            "cwd": "${workspaceFolder}/src/Agent/AgentAlpha",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:agent-alpha",
            "env": {
                "MCP_TRANSPORT": "sse",
                "MCP_SERVER_URL": "http://localhost:3000"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "AgentAlpha (Creative Writing)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Agent/AgentAlpha/bin/Debug/net8.0/AgentAlpha.dll",
            "args": ["--model", "gpt-4o", "--temperature", "0.9", "--system-prompt", "You are a creative writing assistant who helps with storytelling", "--priority", "High", "Write a short story about an AI agent"],
            "cwd": "${workspaceFolder}/src/Agent/AgentAlpha",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:agent-alpha",
            "env": {
                "MCP_TRANSPORT": "sse",
                "MCP_SERVER_URL": "http://localhost:3000"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "AgentAlpha (Precise Math)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Agent/AgentAlpha/bin/Debug/net8.0/AgentAlpha.dll",
            "args": ["--model", "gpt-3.5-turbo", "--temperature", "0.1", "--system-prompt", "You are a precise mathematics tutor", "--timeout", "2", "Calculate the area of a circle with radius 5.7 meters"],
            "cwd": "${workspaceFolder}/src/Agent/AgentAlpha",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:agent-alpha",
            "env": {
                "MCP_TRANSPORT": "sse",
                "MCP_SERVER_URL": "http://localhost:3000"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "AgentAlpha (Quick Test)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Agent/AgentAlpha/bin/Debug/net8.0/AgentAlpha.dll",
            "args": ["--max-iterations", "3", "--verbose", "test"],
            "cwd": "${workspaceFolder}/src/Agent/AgentAlpha",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build:agent-alpha",
            "env": {
                "MCP_TRANSPORT": "sse",
                "MCP_SERVER_URL": "http://localhost:3000"
            },
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}